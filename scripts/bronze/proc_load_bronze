-- NOTE: Run 'SET GLOBAL local_infile = 1' once before executing this script
-- SET GLOBAL local_infile = 1;

SET @batch_start = NOW(6);
SELECT '🚀 Starting Bronze Layer Load...' AS status;
-- ============================================================
-- CRM TABLES
-- ============================================================
SELECT '📂 Loading CRM Tables...' AS status;

-- 1. crm_cust_info
SET @start_1 = NOW(6);
TRUNCATE TABLE bronze.crm_cust_info;
-- Base path: /Users/gomem/Documents/Data analytics/sql-data-warehouse-project/datasets/
-- Update this path if running on a different machine
LOAD DATA LOCAL INFILE '/Users/gomem/Documents/Data analytics/sql-data-warehouse-project/datasets/source_crm/cust_info.csv' 
INTO TABLE bronze.crm_cust_info
FIELDS TERMINATED BY ',' ENCLOSED BY '"'
LINES TERMINATED BY '\n'
IGNORE 1 ROWS;

SET @rows_1 = (SELECT COUNT(*) FROM bronze.crm_cust_info);
SET @dur_1 = CONCAT(TIMESTAMPDIFF(MICROSECOND,@start_1, NOW(6))/1000,' ','ms');
SHOW WARNINGS;

-- 2. crm_prd_info
SET @start_2 = NOW(6);
