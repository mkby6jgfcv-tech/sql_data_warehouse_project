-- ============================================================
-- SUMMARY
-- ============================================================
SELECT 'CRM' AS source_name,'bronze.crm_cust_info' AS table_name, IF(@rows_1 > 0, '✅ Loaded', '❌ 0 rows — check file!') AS status, @rows_1 AS rows_loaded,@dur_1 AS duration UNION ALL
SELECT 'CRM' AS source_name,'bronze.crm_prd_info' AS table_name, IF(@rows_2 > 0, '✅ Loaded', '❌ 0 rows — check file!') AS status, @rows_2 AS rows_loaded,@dur_2 AS duration UNION ALL
