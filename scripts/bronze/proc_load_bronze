    @batch_start AS started_at,
	NOW(6) AS completed_at,
    CONCAT(TIMESTAMPDIFF(MICROSECOND,@batch_start, NOW(6))/1000,' ','ms') AS total_duration,
    @rows_1 + @rows_2 + @rows_3 + @rows_4 + @rows_5 + @rows_6 AS total_rows_loaded;
    
